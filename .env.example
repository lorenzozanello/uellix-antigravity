# Environment contract only. Never commit real credentials.
# Configure distinct values in Vercel Preview and Production.

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Database Connection (Drizzle Kit / Postgres)
DATABASE_URL=

# Gemini API Configuration for Stella AI
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Stella Feature Flags (disabled by default)
STELLA_ENABLED=false
STELLA_ADVISOR_ENABLED=false
STELLA_VALIDATOR_ENABLED=false
STELLA_COMPOSER_ENABLED=false
STELLA_RATE_LIMIT_PER_HOUR=100

# Vercel Deployment & Environment Config
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Resend (invitation/transactional emails)
RESEND_API_KEY=
EMAIL_FROM=Uellix <noreply@uellix.com>
RESEND_FROM_EMAIL=Uellix <noreply@uellix.com>

# Stripe (Monetization & Billing)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_ENTERPRISE=

# Upstash Redis (Rate Limiting)
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Sentry (Error Monitoring & Performance)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
